{
  "name": "@ask-dorian/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:rds": "DOTENV_CONFIG_PATH=.env.production tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "start:rds": "DOTENV_CONFIG_PATH=.env.production node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:force": "tsx src/db/migrate.ts --force",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@koa/cors": "^5.0.0",
    "@koa/multer": "^3.0.2",
    "@koa/router": "^13.1.0",
    "bcryptjs": "^2.4.3",
    "dayjs": "^1.11.13",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.44.0",
    "google-auth-library": "^10.6.1",
    "jsonwebtoken": "^9.0.2",
    "koa": "^3.0.0",
    "koa-bodyparser": "^4.4.1",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.1.0",
    "nodejieba": "^2.6.0",
    "openai": "^4.82.0",
    "pino": "^9.6.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "pino-pretty": "^13.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/koa": "^2.15.0",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa__cors": "^5.0.0",
    "@types/koa__router": "^12.0.4",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.18.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
