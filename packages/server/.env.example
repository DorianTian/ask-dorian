# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Database (PostgreSQL 16 + pgvector)
DATABASE_URL=postgresql://dorian:xxx@localhost:5432/askdorian

# JWT
JWT_SECRET=your-secret-key-at-least-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,https://askdorian.com

# AI — Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_BASE_URL=                  # Optional: proxy URL (e.g. https://api.gptsapi.net)
CLAUDE_SONNET_MODEL=claude-sonnet-4-6
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001

# AI — OpenAI (Embedding + Whisper)
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=                     # Optional: proxy URL (e.g. https://api.gptsapi.net/v1)
EMBEDDING_MODEL=text-embedding-3-small
WHISPER_MODEL=whisper-1

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# File Storage (S3)
S3_BUCKET=ask-dorian-uploads
S3_REGION=ap-southeast-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
