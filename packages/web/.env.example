# === API Configuration ===

# Option 1: Direct connection (no proxy)
# Browser calls this URL directly — needs CORS enabled on backend
# NEXT_PUBLIC_API_URL=http://localhost:4000

# Option 2: Dev proxy (recommended)
# Leave NEXT_PUBLIC_API_URL empty, set API_PROXY_TARGET instead.
# All /api/* requests are proxied through Next.js dev server — no CORS issues.
NEXT_PUBLIC_API_URL=
API_PROXY_TARGET=http://localhost:4000
